<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- 跨平台还原：稳定版 Godot.NET.Sdk / GodotSharp 均发布在 nuget.org，无需引用某平台下
       Godot 安装目录里的本地 nupkgs（那是绝对路径，不可移植）。如需离线/锁定精确版本，可
       临时加一个指向本机 <Godot 安装目录>/GodotSharp/Tools/nupkgs 的 <add> 源。 -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
